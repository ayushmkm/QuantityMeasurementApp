import java.util.Scanner;

class QuantityMeasurementApp {

    public boolean areEqual(double value1, double value2) {
        return Double.compare(value1, value2) == 0;
    }

    public boolean isValidNumber(String input) {
        try {
            Double.parseDouble(input);
            return true;
        } catch (NumberFormatException e) {
            return false;
        }
    }

    public double parseValue(String input) {
        return Double.parseDouble(input);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        QuantityMeasurementApp app = new QuantityMeasurementApp();

        System.out.print("Enter first value in feet: ");
        String input1 = scanner.nextLine();

        System.out.print("Enter second value in feet: ");
        String input2 = scanner.nextLine();

        if (!app.isValidNumber(input1) || !app.isValidNumber(input2)) {
            System.out.println("Invalid input");
            return;
        }

        double value1 = app.parseValue(input1);
        double value2 = app.parseValue(input2);

        boolean result = app.areEqual(value1, value2);

        System.out.println(result);

        scanner.close();
    }
}
