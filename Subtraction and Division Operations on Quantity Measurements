public class QuantityMeasurementApp {

```
public static void main(String[] args) {

    Quantity<LengthUnit> length1 = new Quantity<>(10, LengthUnit.FOOT);
    Quantity<LengthUnit> length2 = new Quantity<>(6, LengthUnit.INCH);

    System.out.println("Length Subtraction:");
    System.out.println(length1.subtract(length2));
    System.out.println(length1.subtract(length2, LengthUnit.YARD));
    System.out.println("Length Division: " + length1.divide(new Quantity<>(5, LengthUnit.FOOT)));

    Quantity<WeightUnit> weight1 = new Quantity<>(5, WeightUnit.KILOGRAM);
    Quantity<WeightUnit> weight2 = new Quantity<>(500, WeightUnit.GRAM);

    System.out.println("\nWeight Subtraction:");
    System.out.println(weight1.subtract(weight2));
    System.out.println(weight1.subtract(weight2, WeightUnit.POUND));
    System.out.println("Weight Division: " + weight1.divide(new Quantity<>(2500, WeightUnit.GRAM)));

    Quantity<VolumeUnit> volume1 = new Quantity<>(5, VolumeUnit.LITRE);
    Quantity<VolumeUnit> volume2 = new Quantity<>(2000, VolumeUnit.MILLILITRE);

    System.out.println("\nVolume Subtraction:");
    System.out.println(volume1.subtract(volume2));
    System.out.println(volume1.subtract(volume2, VolumeUnit.GALLON));
    System.out.println("Volume Division: " + volume1.divide(new Quantity<>(2500, VolumeUnit.MILLILITRE)));
}
```

}

interface IMeasurable {
double convertToBaseUnit(double value);
double convertFromBaseUnit(double value);
}

enum LengthUnit implements IMeasurable {

```
FOOT(30.48),
INCH(2.54),
YARD(91.44),
CENTIMETER(1.0);

private final double factor;

LengthUnit(double factor) {
    this.factor = factor;
}

public double convertToBaseUnit(double value) {
    return value * factor;
}

public double convertFromBaseUnit(double value) {
    return value / factor;
}
```

}

