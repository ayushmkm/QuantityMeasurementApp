    }
}

public class QuantityMeasurementApp {
    public static void main(String[] args) {

        QuantityWeight w1 = new QuantityWeight(1, WeightUnit.KILOGRAM);
        QuantityWeight w2 = new QuantityWeight(1000, WeightUnit.GRAM);

        System.out.println(w1.equals(w2));

        QuantityWeight converted =
                new QuantityWeight(2, WeightUnit.POUND)
                        .convertTo(WeightUnit.GRAM);

        System.out.println(converted);

        QuantityWeight sum1 =
                new QuantityWeight(1, WeightUnit.KILOGRAM)
                        .add(new QuantityWeight(500, WeightUnit.GRAM));

        System.out.println(sum1);

        QuantityWeight sum2 =
                new QuantityWeight(1, WeightUnit.KILOGRAM)
                        .add(new QuantityWeight(2, WeightUnit.POUND),
                                WeightUnit.POUND);

        System.out.println(sum2);

        QuantityLength l1 = new QuantityLength(1, LengthUnit.FEET);
        QuantityLength l2 = new QuantityLength(12, LengthUnit.INCH);

        System.out.println(l1.equals(l2));

        QuantityLength lengthSum = l1.add(l2);

        System.out.println(lengthSum);
    }
}
